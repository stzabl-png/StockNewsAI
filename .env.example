# ============================================
# NewsAnalysisForStock - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://stocknews:stocknews_dev@db:5432/stocknews

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- API Keys ----------
# Finnhub (https://finnhub.io)
FINNHUB_API_KEY=

# OpenAI (https://platform.openai.com) - GPT-4o-mini 初筛
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com) - Claude Sonnet 深度分析
ANTHROPIC_API_KEY=

# ---------- 微信推送 (WxPusher) ----------
WXPUSHER_APP_TOKEN=
WXPUSHER_UIDS=

# ---------- Telegram 推送 ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- App Settings ----------
APP_NAME=NewsAnalysisForStock
DEBUG=true
